# =====================================================
# TELEGRAM CREDENTIALS (required)
# =====================================================
# Get your API ID and hash from https://my.telegram.org/apps
TELEGRAM_API_ID=24270724
TELEGRAM_API_HASH=a77ccb6cb3a305e0cbadedb021c6d9f6
# Your phone number in international format (e.g., +1234567890)
TELEGRAM_PHONE=+9779819204312
# Where to store the Telegram session (do not change unless you know what you're doing)
TELEGRAM_SESSION=data/telegram_user

# =====================================================
# DESTINATION (required)
# =====================================================
# The Telegram channel/chat where messages will be forwarded.
# Use -100XXXXXXXXXX for channels/supergroups.
DESTINATION_CHANNEL_ID=-1001406946667

# =====================================================
# ADMIN (required)
# =====================================================
# Your numeric Telegram user ID (find it via @userinfobot or similar)
ADMIN_USER_ID=1307286874

# =====================================================
# DISCORD – choose one of the two options below
# =====================================================
# Option A – Discord bot (only works if you can invite the bot to your servers)
# Leave DISCORD_TOKEN empty if you use the scraper.
DISCORD_TOKEN=

# Option B – Discord scraper (uses your own Discord login, works in any server you're a member of)
# Provide your Discord email and password (2FA supported – you'll enter the code in the browser).
DISCORD_EMAIL=manishneuane758@gmail.com
DISCORD_PASSWORD=m@ni$h9869
# Comma‑separated list of Discord channel IDs (numeric snowflakes)
DISCORD_CHANNELS=1510278627990966544,1510278875677200555,1510279321158287571,1510279405145030726,1510280525422792885,1510280564706377788,1510280716351701003
# Set to true to see the browser window (useful for debugging & 2FA), false to run headless
DISCORD_SHOW_BROWSER=true

# =====================================================
# STORAGE & LOGGING
# =====================================================
DATA_DIR=data
TMP_DIR=tmp
LOG_LEVEL=INFO

# =====================================================
# MEDIA PROCESSING
# =====================================================
MAX_FILE_SIZE_MB=45              # maximum file size to forward (MB)
COMPRESS_IMAGES=true             # compress large images to reduce size
MAX_IMAGE_SIZE_MB=5              # target max image size after compression (MB)
CONVERT_WEBP_TO_JPG=true         # convert WebP images to JPG
GENERATE_VIDEO_THUMBNAILS=true   # generate and forward a thumbnail for videos
TRANSCODE_VIDEOS=false           # transcode videos to H.264/AAC (may reduce size)
WATERMARK_TEXT=                  # leave empty for no watermark, or add text like "© My Channel"

# =====================================================
# FORWARDING BEHAVIOR
# =====================================================
INCLUDE_SOURCE=true              # include source channel name in the forwarded message
INCLUDE_AUTHOR=true              # include original author's name
INCLUDE_TIMESTAMP=true           # include original timestamp
INCLUDE_LINK=true                # add a clickable link to the original message
QUEUE_MAX_RETRIES=3              # how many times to retry failed messages

# =====================================================
# PROTECTED TELEGRAM CONTENT
# =====================================================
# This app will NOT bypass Telegram's restrictions.
# If enabled, the admin will receive a notification about skipped protected media.
NOTIFY_PROTECTED_CONTENT=true

# =====================================================
# WEB CONTROL PANEL (optional)
# =====================================================
WEB_UI_ENABLED=true
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=8080
# Set a strong token to secure the UI – if empty, no authentication is enforced.
WEB_UI_TOKEN=
# Enable the Telegram web scraper (fallback for protected media)
TELEGRAM_SCRAPER_ENABLED=true
# Show browser window? false = headless, true = debug (set to false on Replit)
TELEGRAM_SHOW_BROWSER=false
# How often to poll channels that require scraping (seconds)
TELEGRAM_SCRAPER_POLL_INTERVAL=20
DISCORD_SHOW_BROWSER=false